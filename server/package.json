{
  "name": "noneco-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src",
    "db:migrate": "node src/db/migrations/migrate.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "fast-check": "^3.23.2",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
