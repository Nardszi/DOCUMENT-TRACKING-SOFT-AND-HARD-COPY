# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin.
# For local development use individual vars below instead.
DATABASE_URL=postgresql://user:password@host:5432/noneco_docs

# Local development (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noneco_docs
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Set to true if your PostgreSQL requires SSL (Railway does)
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30m

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── File storage ───────────────────────────────────────────────────────────────
# 'local' stores files in UPLOADS_DIR (not suitable for Railway — use 'minio')
# 'minio' uses any S3-compatible storage (Cloudflare R2, AWS S3, MinIO)
STORAGE_BACKEND=local
UPLOADS_DIR=./uploads

# MinIO / S3-compatible (required if STORAGE_BACKEND=minio)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=noneco-documents

# ── App URL ────────────────────────────────────────────────────────────────────
# In production set this to your Railway public URL, e.g.:
# APP_URL=https://noneco-dts.up.railway.app
APP_URL=http://localhost:5173
CORS_ORIGIN=*

# ── Email (optional) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@noneco.example.com
SMTP_PASS=smtp-password
EMAIL_FROM=NONECO DTS <noreply@noneco.example.com>
